{
  "version": 3,
  "name": "CanBankX API Gateway",
  "timeout": "15000ms",
  "port": 8080,
  "endpoints": [
    {
      "endpoint": "/actuator/health",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://nginx"
          ],
          "url_pattern": "/actuator/health",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/customers",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://nginx"
          ],
          "url_pattern": "/api/v1/customers",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/customers/{customerId}/kyc/approve",
      "method": "PATCH",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://nginx"
          ],
          "url_pattern": "/api/v1/customers/{customerId}/kyc/approve",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/customers/{customerId}/accounts",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://nginx"
          ],
          "url_pattern": "/api/v1/customers/{customerId}/accounts",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/accounts/{accountId}/balance",
      "method": "GET",
      "input_headers": [
        "Authorization",
        "Content-Type",
        "X-Customer-Id"
      ],
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://nginx"
          ],
          "url_pattern": "/api/v1/accounts/{accountId}/balance",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/accounts/{accountId}/ledger",
      "method": "GET",
      "input_headers": [
        "Authorization",
        "Content-Type",
        "X-Customer-Id"
      ],
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://nginx"
          ],
          "url_pattern": "/api/v1/accounts/{accountId}/ledger",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/transfers",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type",
        "X-Customer-Id",
        "Idempotency-Key"
      ],
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://nginx"
          ],
          "url_pattern": "/api/v1/transfers",
          "encoding": "no-op"
        }
      ]
    }
  ]
}